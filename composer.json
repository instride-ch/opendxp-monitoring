{
  "name": "instride/opendxp-monitoring",
  "type": "opendxp-bundle",
  "description": "Monitoring for OpenDXP instances",
  "keywords": [
    "opendxp",
    "opendxp-bundle"
  ],
  "homepage": "https://github.com/instride-ch/opendxp-monitoring",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "instride AG",
      "email": "connect@instride.ch",
      "homepage": "https://instride.ch",
      "role": "Digital Agency"
    }
  ],
  "require": {
    "laminas/laminas-diagnostics": "^1.30",
    "open-dxp/opendxp": "^1.3",
    "spatie/ssl-certificate": "^2.6",
    "symfony/http-client": "^7.4"
  },
  "require-dev": {
    "deployer/deployer": "^8.0",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Instride\\Bundle\\OpenDxpMonitoringBundle\\": "src/"
    }
  },
  "extra": {
    "opendxp": {
      "bundles": [
        "Instride\\Bundle\\OpenDxpMonitoringBundle\\OpenDxpMonitoringBundle"
      ]
    }
  }
}
